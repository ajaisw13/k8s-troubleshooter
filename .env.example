# FastAPI backend URL (used by the UI service)
AGENT_API_URL=http://localhost:8000

# Kubernetes namespace to target (defaults to "default")
K8S_NAMESPACE=default

# Optional API key — if set, all endpoints require X-API-Key header
# API_KEY=your-secret-key

# AWS (required for EKS)
AWS_DEFAULT_REGION=us-west-2

# GCP (required for GKE — alternatively mount a service account key and set
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json)
# GOOGLE_CLOUD_PROJECT=your-gcp-project
